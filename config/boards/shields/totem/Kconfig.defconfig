# In the dongle setup BOTH halves are peripherals; the dongle is the sole
# central. (Previously totem_left was central.)
if SHIELD_TOTEM_LEFT || SHIELD_TOTEM_RIGHT

config ZMK_KEYBOARD_NAME
    default "TOTEM"

config ZMK_SPLIT
    default y

# The shared totem keymap references &mkp (trackball buttons, bound on the
# central). Split peripherals still compile the keymap, so the pointing
# behaviors must resolve here too, or the totem_left/right devicetree build
# fails on an undefined &mkp phandle. No pointing hardware runs on the halves.
config ZMK_POINTING
    default y

endif

if SHIELD_TOTEM_DONGLE

config ZMK_KEYBOARD_NAME
    default "TOTEM"

config ZMK_SPLIT
    default y

config ZMK_SPLIT_ROLE_CENTRAL
    default y

# Left half + right half + Adept trackball
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 3

# 3 peripherals + host BT profiles
config BT_MAX_CONN
    default 8

config BT_MAX_PAIRED
    default 8

# Pointing (trackball forwarded over the split) and per-peripheral battery
config ZMK_POINTING
    default y

config ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_FETCHING
    default y

endif
